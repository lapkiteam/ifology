{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "vite.config.js"]
}
